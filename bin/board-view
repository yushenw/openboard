#!/usr/bin/env bash
# board-view — read-only terminal dashboard for OpenBoard. NEVER writes to the board.
# Composes the read-only board CLI commands into a refreshing panel.
# Usage: board-view [--once | --interval N] [-n <activity-lines>]
set -u
# Resolve our REAL location first (install.sh symlinks from <prefix>/bin), then OB_HOME
# from env > `.openboard/` marker > script location (see bin/ob-common.sh).
_src=${BASH_SOURCE[0]}
while [ -h "$_src" ]; do
  _d=$(cd -P "$(dirname "$_src")" && pwd); _src=$(readlink "$_src")
  case "$_src" in /*) ;; *) _src="$_d/$_src" ;; esac
done
OB_BIN_DIR=$(cd -P "$(dirname "$_src")" && pwd)
. "$OB_BIN_DIR/ob-common.sh"
ob_resolve_home "$_src" || { echo "board-view: cannot locate OpenBoard root (set OB_HOME)" >&2; exit 2; }
BOARD_BIN="${BOARD_BIN:-$OB_BIN_DIR/board}"
N_ACTIVITY=12
INTERVAL=0                     # 0 = render once and exit

while [ $# -gt 0 ]; do
  case "$1" in
    --once)     INTERVAL=0; shift ;;
    --interval) INTERVAL=${2:?}; shift 2 ;;
    -n)         N_ACTIVITY=${2:?}; shift 2 ;;
    *) echo "usage: board-view [--once | --interval N] [-n activity-lines]" >&2; exit 2 ;;
  esac
done

hr()  { printf '%s\n' "----------------------------------------------------------------"; }
sect(){ printf '\n== %s ==\n' "$1"; }

render() {
  local now; now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  hr; printf ' OpenBoard  ·  %s  ·  %s\n' "$now" "$OB_HOME"; hr

  sect "AGENTS"
  OB_AGENT=view "$BOARD_BIN" who 2>/dev/null || echo '(none)'

  sect "TASKS"
  OB_AGENT=view "$BOARD_BIN" task list 2>/dev/null || echo '(none)'

  sect "RECENT ACTIVITY (last $N_ACTIVITY)"
  OB_AGENT=view "$BOARD_BIN" read -n "$N_ACTIVITY" 2>/dev/null \
    | awk '/^## /{id=$2} /^type:/{printf "  %-10s %-9s %s\n", $4, $2, id}'
  printf '\n'
}

if [ "$INTERVAL" -gt 0 ] 2>/dev/null; then
  while :; do
    clear 2>/dev/null || printf '\033[2J\033[H'
    render
    printf '(refresh %ss · Ctrl-C to quit)\n' "$INTERVAL"
    sleep "$INTERVAL"
  done
else
  render
fi
