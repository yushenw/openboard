#!/usr/bin/env bash
# board-watch — poll-based sync/notify companion for OpenBoard
# Pure bash, zero deps beyond coreutils. Consumes the frozen board conventions
# (Tier-1 docs/board-cli-spec.md + Tier-2 docs/board-cli-spec-tier2.md). It does
# NOT change the CLI surface.
#
# Notices fire when, since the last scan:
#   1. a new message @mentions an agent in its body                  -> notify that agent
#   2. a new message's type is question|review                       -> notify all registered agents
#   3. a new message is a TASK lifecycle event:
#        - type=claim    whose slug is a TASK-<NNN>-... id            -> "task <id> claimed"
#        - type=decision with a task: field (no winner)              -> "task <id> closed"
#        - type=decision with winner:+task: (Tier-3 promote)         -> "task <id> promoted (winner <rid>)"
#        - type=result   with metric_value:+task: (Tier-3)           -> "new result for <id> (metric=<v>)"
#   4. a new tasks/TASK-*.md spec file appears                        -> "new task <id>"
# For (2)-(4) every registered agent except the actor/creator is notified.
# Each agent is notified at most once per source (mentions+broadcast combine).
#
# Each notice is printed to stdout AND appended (one line) to board/inbox/<agent>.md.
#
# Usage:
#   board-watch --once                   single scan
#   board-watch --interval N             loop every N seconds (default: 10)
#   board-watch --once --digest          also run `board digest --write` if the CLI supports it
#   board-watch --interval 30 --digest   ...on every interval
#
# Environment:
#   OB_HOME       repo root (default: parent of this script's dir)
#   OB_BOARD      board directory (default: $OB_HOME/board)
#   OB_INBOX      inbox dir for notices (default: $OB_BOARD/inbox)
#   OB_STATE      cursor/state dir (default: /tmp/board-watch-state)
#   OB_BOARD_CLI  board CLI used by --digest (default: $OB_HOME/bin/board, then bin/board.sh)

set -euo pipefail
export LC_ALL=C   # deterministic byte-order string comparison (matches board.sh)

# ---------------------------------------------------------------------------
# Config / defaults
# ---------------------------------------------------------------------------
# Resolve our REAL location (install.sh symlinks from <prefix>/bin), then OB_HOME from
# env > `.openboard/` marker > script location (see bin/ob-common.sh).
_src=${BASH_SOURCE[0]}
while [ -h "$_src" ]; do
  _d=$(cd -P "$(dirname "$_src")" && pwd); _src=$(readlink "$_src")
  case "$_src" in /*) ;; *) _src="$_d/$_src" ;; esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
. "$SCRIPT_DIR/ob-common.sh"
ob_resolve_home "$_src" || { echo "board-watch: cannot locate OpenBoard root (set OB_HOME)" >&2; exit 2; }
OB_BOARD="${OB_BOARD:-$OB_HOME/board}"
OB_STATE="${OB_STATE:-/tmp/board-watch-state}"

MESSAGES_DIR="$OB_BOARD/messages"
AGENTS_DIR="$OB_BOARD/agents"
INBOX_DIR="${OB_INBOX:-$OB_BOARD/inbox}"
TASKS_DIR="$OB_HOME/tasks"
MSG_CURSOR="$OB_STATE/cursor"
TASK_CURSOR="$OB_STATE/tasks-cursor"

# Resolve the board CLI for --digest (capability-checked before use).
if [[ -n "${OB_BOARD_CLI:-}" ]]; then
    BOARD_CLI="$OB_BOARD_CLI"
elif [[ -x "$OB_HOME/bin/board" ]]; then
    BOARD_CLI="$OB_HOME/bin/board"
elif [[ -x "$OB_HOME/bin/board.sh" ]]; then
    BOARD_CLI="$OB_HOME/bin/board.sh"
else
    BOARD_CLI=""
fi

# ---------------------------------------------------------------------------
# Parse args
# ---------------------------------------------------------------------------
MODE="interval"
INTERVAL=10
DO_DIGEST=0

usage() {
    echo "Usage: board-watch --once | --interval N [--digest]" >&2
    exit 2
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --once)     MODE="once"; shift ;;
        --interval) MODE="interval"; INTERVAL="${2:?--interval requires a number}"; shift 2 ;;
        --digest)   DO_DIGEST=1; shift ;;
        --help|-h)  usage ;;
        *) echo "Unknown option: $1" >&2; usage ;;
    esac
done

# ---------------------------------------------------------------------------
# Small helpers
# ---------------------------------------------------------------------------
ts_now() { date -u +%Y%m%dT%H%M%SZ; }

# contains <value> <list...>  -> 0 if value is in the list
contains() {
    local v=$1; shift
    local x
    for x in "$@"; do [[ "$x" == "$v" ]] && return 0; done
    return 1
}

# extract_task_id <string>  -> first TASK-<NNN>-... token (case-insensitive), or empty
extract_task_id() {
    printf '%s\n' "$1" | grep -oiE 'task-[0-9]+[a-z0-9_-]*' | head -1 || true
}

# emit_notice <agent> <detail>  -> print + append one line to that agent's inbox
emit_notice() {
    local agent="$1" detail="$2"
    local notice="[$(ts_now)] notice: $detail"
    echo "$notice"
    mkdir -p "$INBOX_DIR"
    echo "$notice" >> "$INBOX_DIR/${agent}.md"
}

# list registered agent names (basenames of board/agents/*.md), one per line
registered_agents() {
    local af
    while IFS= read -r af; do
        [[ -z "$af" || ! -f "$af" ]] && continue
        basename "$af" .md
    done < <(ls -1 "$AGENTS_DIR"/*.md 2>/dev/null || true)
}

# parse_message <file> -> sets MSG_ID MSG_AUTHOR MSG_TYPE MSG_SLUG MSG_REFS
#                          MSG_TASK MSG_WINNER MSG_MVAL MSG_BODY
parse_message() {
    local f="$1" line in_front=0 past_front=0
    MSG_ID=""; MSG_AUTHOR=""; MSG_TYPE=""; MSG_SLUG=""; MSG_REFS=""
    MSG_TASK=""; MSG_WINNER=""; MSG_MVAL=""; MSG_BODY=""
    while IFS= read -r line; do
        if [[ "$line" == "---" ]]; then
            if [[ $in_front -eq 0 ]]; then in_front=1; else past_front=1; in_front=0; fi
            continue
        fi
        if [[ $in_front -eq 1 ]]; then
            case "$line" in
                id:\ *)           MSG_ID="${line#id: }" ;;
                author:\ *)       MSG_AUTHOR="${line#author: }" ;;
                type:\ *)         MSG_TYPE="${line#type: }" ;;
                slug:\ *)         MSG_SLUG="${line#slug: }" ;;
                refs:\ *)         MSG_REFS="${line#refs: }" ;;
                task:\ *)         MSG_TASK="${line#task: }" ;;
                winner:\ *)       MSG_WINNER="${line#winner: }" ;;
                metric_value:\ *) MSG_MVAL="${line#metric_value: }" ;;
            esac
        elif [[ $past_front -eq 1 ]]; then
            MSG_BODY="$MSG_BODY
$line"
        fi
    done < "$f"
    MSG_BODY="${MSG_BODY#$'\n'}"
}

# ---------------------------------------------------------------------------
# Scan board/messages/ for new messages
# ---------------------------------------------------------------------------
scan_messages() {
    mkdir -p "$OB_STATE"
    local last_seen new_latest found_any=0
    last_seen="$(cat "$MSG_CURSOR" 2>/dev/null || echo "")"
    new_latest="$last_seen"

    local files=()
    while IFS= read -r f; do files+=("$f"); done \
        < <(ls -1 "$MESSAGES_DIR"/*.md 2>/dev/null | sort || true)

    local f base
    for f in "${files[@]:-}"; do
        [[ -z "$f" || ! -f "$f" ]] && continue
        base="$(basename "$f")"
        # skip anything at or before the cursor (no <= in bash string compare)
        if [[ -n "$last_seen" && ( "$base" < "$last_seen" || "$base" == "$last_seen" ) ]]; then
            continue
        fi
        found_any=1
        [[ -z "$new_latest" || "$base" > "$new_latest" ]] && new_latest="$base"

        parse_message "$f"

        # --- broadcast reason (question/review OR a task lifecycle event) ---
        # Task id for decision/result events comes from the `task:` field (Tier-2/3
        # CLI writes it there). Claims carry the id in the slugified `slug:` field.
        local broadcast_reason="" tid
        case "$MSG_TYPE" in
            question|review) broadcast_reason="type=$MSG_TYPE" ;;
            claim)
                tid="$(extract_task_id "$MSG_SLUG")"
                [[ -n "$tid" ]] && broadcast_reason="task $tid claimed" ;;
            decision)
                # Tier-3 promote: a decision carrying winner:+task: (check FIRST — a
                # promote decision also has a task:, but is a promote, not a close).
                if [[ -n "$MSG_WINNER" && -n "$MSG_TASK" ]]; then
                    broadcast_reason="task $MSG_TASK promoted (winner $MSG_WINNER)"
                elif [[ -n "$MSG_TASK" ]]; then
                    broadcast_reason="task $MSG_TASK closed"
                fi ;;
            result)
                # Tier-3 competing result carrying a primary metric_value.
                if [[ -n "$MSG_MVAL" && -n "$MSG_TASK" ]]; then
                    broadcast_reason="new result for $MSG_TASK (metric=$MSG_MVAL)"
                fi ;;
        esac

        # --- collect @mentioned agents (exact tokens) ---
        local mentions=() m
        while IFS= read -r m; do
            [[ -z "$m" ]] && continue
            contains "$m" "${mentions[@]:-}" || mentions+=("$m")
        done < <(printf '%s\n' "$MSG_BODY" | grep -oE '@[A-Za-z0-9_-]+' | sed 's/^@//' || true)

        # --- collect broadcast targets (all registered except author) ---
        local targets=() a
        if [[ -n "$broadcast_reason" ]]; then
            while IFS= read -r a; do
                [[ -z "$a" || "$a" == "$MSG_AUTHOR" ]] && continue
                targets+=("$a")
            done < <(registered_agents)
        fi

        # --- union, dedup, emit one notice per agent (reasons combined) ---
        local recipients=() agent
        for agent in "${mentions[@]:-}" "${targets[@]:-}"; do
            [[ -z "$agent" ]] && continue
            contains "$agent" "${recipients[@]:-}" || recipients+=("$agent")
        done
        for agent in "${recipients[@]:-}"; do
            [[ -z "$agent" ]] && continue
            local reason=""
            if contains "$agent" "${mentions[@]:-}"; then reason="@mention"; fi
            if [[ -n "$broadcast_reason" ]] && contains "$agent" "${targets[@]:-}"; then
                [[ -n "$reason" ]] && reason="$reason + $broadcast_reason" || reason="$broadcast_reason"
            fi
            [[ -z "$reason" ]] && continue
            emit_notice "$agent" "$reason in $MSG_ID (by $MSG_AUTHOR, type=$MSG_TYPE)"
        done
    done

    [[ $found_any -eq 1 && -n "$new_latest" ]] && printf '%s' "$new_latest" > "$MSG_CURSOR"
    return 0
}

# ---------------------------------------------------------------------------
# Scan tasks/ for new TASK spec files
# ---------------------------------------------------------------------------
scan_tasks() {
    [[ -d "$TASKS_DIR" ]] || return 0
    mkdir -p "$OB_STATE"
    local last_seen new_latest found_any=0
    last_seen="$(cat "$TASK_CURSOR" 2>/dev/null || echo "")"
    new_latest="$last_seen"

    local files=()
    while IFS= read -r f; do files+=("$f"); done \
        < <(ls -1 "$TASKS_DIR"/TASK-*.md 2>/dev/null | sort || true)

    local f base
    for f in "${files[@]:-}"; do
        [[ -z "$f" || ! -f "$f" ]] && continue
        base="$(basename "$f")"
        if [[ -n "$last_seen" && ( "$base" < "$last_seen" || "$base" == "$last_seen" ) ]]; then
            continue
        fi
        found_any=1
        [[ -z "$new_latest" || "$base" > "$new_latest" ]] && new_latest="$base"

        # task id from frontmatter (fallback: filename stem); creator from created_by
        local tid creator
        tid="$(grep -m1 -E '^id:[[:space:]]' "$f" 2>/dev/null | sed -E 's/^id:[[:space:]]*//' || true)"
        [[ -z "$tid" ]] && tid="${base%.md}"
        creator="$(grep -m1 -E '^created_by:[[:space:]]' "$f" 2>/dev/null | sed -E 's/^created_by:[[:space:]]*//' || true)"

        local a
        while IFS= read -r a; do
            [[ -z "$a" ]] && continue
            [[ -n "$creator" && "$a" == "$creator" ]] && continue
            emit_notice "$a" "new task $tid (by ${creator:-?})"
        done < <(registered_agents)
    done

    [[ $found_any -eq 1 && -n "$new_latest" ]] && printf '%s' "$new_latest" > "$TASK_CURSOR"
    return 0
}

# ---------------------------------------------------------------------------
# Optional: run `board digest --write` if the CLI advertises a digest subcommand
# ---------------------------------------------------------------------------
maybe_digest() {
    [[ $DO_DIGEST -eq 1 ]] || return 0
    if [[ -z "$BOARD_CLI" || ! -x "$BOARD_CLI" ]]; then
        echo "[board-watch] --digest: no board CLI found, skipping" >&2
        return 0
    fi
    # Capability check: does the CLI list a 'digest' subcommand in its help/usage?
    if OB_HOME="$OB_HOME" OB_BOARD="$OB_BOARD" "$BOARD_CLI" help 2>&1 | grep -qw digest; then
        if OB_HOME="$OB_HOME" OB_BOARD="$OB_BOARD" "$BOARD_CLI" digest --write >/dev/null 2>&1; then
            echo "[board-watch] digest written to $OB_BOARD/digest.md" >&2
        else
            echo "[board-watch] --digest: 'digest --write' failed" >&2
        fi
    else
        echo "[board-watch] --digest: board CLI has no 'digest' subcommand yet, skipping" >&2
    fi
    return 0
}

scan_cycle() {
    scan_messages
    scan_tasks
    maybe_digest
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
mkdir -p "$OB_STATE" "$INBOX_DIR"

if [[ "$MODE" == "once" ]]; then
    scan_cycle
else
    echo "[board-watch] polling every ${INTERVAL}s (Ctrl-C to stop)" >&2
    while true; do
        scan_cycle
        sleep "$INTERVAL"
    done
fi
