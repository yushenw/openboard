#!/usr/bin/env bash
# board-join <agent> [role] [--worktree|--no-worktree] — one-command onboarding (decision 0012):
# provision the agent's git worktree (when the board root is a git repo) + local identity +
# shared-board redirect, register on the board, then run `board doctor` — a join only counts
# when doctor is green (no more silent writes into the void).
set -u
# Resolve OB_HOME from env > `.openboard/` marker > this script's location (see bin/ob-common.sh).
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/ob-common.sh"
ob_resolve_home "${BASH_SOURCE[0]}" || {
  echo "board-join: cannot locate OpenBoard root (set OB_HOME, or \`board init\` a directory first)" >&2; exit 2; }
# CLI lives next to THIS script (the install), not necessarily under OB_HOME.
BOARD="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/board"

agent="" role="" wt=auto
while [ $# -gt 0 ]; do
  case "$1" in
    --worktree)    wt=yes; shift ;;
    --no-worktree) wt=no; shift ;;
    -*) echo "board-join: unknown flag '$1'" >&2; exit 2 ;;
    *)  if [ -z "$agent" ]; then agent=$1; elif [ -z "$role" ]; then role=$1
        else echo "board-join: unexpected arg '$1'" >&2; exit 2; fi; shift ;;
  esac
done
[ -n "$agent" ] || { echo "usage: board-join <agent> [role] [--worktree|--no-worktree]" >&2; exit 2; }
role=${role:-contributor}

# 1) code workspace: sibling worktree ../ob-<agent> on branch agent/<agent>.
#    auto: only when the board root is a git repo; reuse an existing branch/dir rather than fail.
wt_dir="$(dirname "$OB_HOME")/ob-$agent"
if [ "$wt" != no ] && git -C "$OB_HOME" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  if [ -d "$wt_dir" ]; then
    echo "worktree: $wt_dir (already present, kept)"
  elif git -C "$OB_HOME" show-ref --verify --quiet "refs/heads/agent/$agent"; then
    git -C "$OB_HOME" worktree add "$wt_dir" "agent/$agent" >/dev/null \
      || { echo "board-join: git worktree add failed (existing branch agent/$agent)" >&2; exit 1; }
    echo "worktree: $wt_dir (reusing existing branch agent/$agent)"
  else
    git -C "$OB_HOME" worktree add -b "agent/$agent" "$wt_dir" >/dev/null \
      || { echo "board-join: git worktree add failed" >&2; exit 1; }
    echo "worktree: $wt_dir (new branch agent/$agent)"
  fi
  # local identity + shared-board redirect (all gitignored; board-hook picks these up)
  printf '%s\n' "$agent" > "$wt_dir/.ob-agent"
  printf '%s\n' "$role"  > "$wt_dir/.ob-role"
  mkdir -p "$wt_dir/.openboard"
  printf '# per-checkout override (gitignored): point this worktree at the SHARED board.\nOB_HOME=%s\n' \
    "$OB_HOME" > "$wt_dir/.openboard/local"
elif [ "$wt" = yes ]; then
  echo "board-join: --worktree requested but $OB_HOME is not a git repo" >&2; exit 2
fi

# 2) register on the board
OB_AGENT="$agent" "$BOARD" register --role "$role" >/dev/null || {
  echo "board-join: register failed" >&2; exit 1; }

# 3) self-check — the join only counts when doctor is green
OB_AGENT="$agent" "$BOARD" doctor || {
  echo "board-join: doctor found failures — fix the red lines above, then re-run." >&2; exit 1; }

cat <<EOF

joined OpenBoard as '$agent' (role: $role).

next:
  export OB_HOME=$OB_HOME OB_AGENT=$agent
EOF
[ -d "$wt_dir" ] && printf '  cd %s        # your code workspace (branch agent/%s)\n' "$wt_dir" "$agent"
cat <<EOF
  $BOARD new                 # read unread messages
  $BOARD task list           # see the task board

fresh-TUI paste block:  $BOARD brief --paste --role $role
always CLAIM before you work:  $BOARD task claim <id> -m "why me"
EOF
